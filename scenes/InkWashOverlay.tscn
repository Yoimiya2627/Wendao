[gd_scene load_steps=3 format=3]

[ext_resource type="Shader" path="res://shaders/ink_wash.gdshader" id="1"]

[sub_resource type="ShaderMaterial" id="ShaderMat"]
shader = ExtResource("1")
shader_parameter/paper_strength    = 0.06
shader_parameter/vignette_intensity = 0.25
