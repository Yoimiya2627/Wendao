{
  "scenes": {

    "suming": {
      "title": "清晨·苏明",
      "start": "sm_01",
      "nodes": {
        "sm_01": {
          "speaker": "苏明",
          "text": "云晚。",
          "next": "sm_02"
        },
        "sm_02": {
          "speaker": "苏明",
          "text": "去吧。不管测出什么，记得回来吃饭。",
          "next": "sm_03"
        },
        "sm_03": {
          "type": "narration",
          "text": "爹向来不多说话。这句\u201c记得回来吃饭\u201d，却让她鼻子微微一酸。"
        }
      }
    },

    "niannian": {
      "title": "年年",
      "start": "nn_01",
      "nodes": {
        "nn_01": {
          "speaker": "年年",
          "text": "喵——（年年用爪子扯你的袖子）"
        }
      }
    },

    "dayu": {
      "title": "大鱼",
      "start": "dy_01",
      "nodes": {
        "dy_01": {
          "type": "narration",
          "text": "大鱼从柜台上跳下来，用巨大的脑袋蹭了蹭你的腿。"
        }
      }
    },

    "morning": {
      "title": "清晨·杂货铺",
      "start": "m_01",
      "nodes": {
        "m_01": {
          "type": "narration",
          "text": "初春时节，岭南小城里的杂货铺还没开门。皂角和桂皮的气味混在晨雾里，窗台上的薄荷刚从砖缝里钻出嫩芽。",
          "next": "m_02"
        },
        "m_02": {
          "type": "narration",
          "text": "年年趴在门槛上，见云晚要出门，抬起头看了她一眼。云晚蹲下来，揉了揉它的脑袋。它没有躲，轻轻地把头往她手心里靠了靠，然后闭上眼睛。",
          "next": "m_03"
        },
        "m_03": {
          "speaker": "苏云晚",
          "text": "今天去测灵根，你说能不能测出来？",
          "next": "m_04"
        },
        "m_04": {
          "type": "narration",
          "text": "年年没有回答，只是安静地靠着她的手。",
          "next": "m_05"
        },
        "m_05": {
          "type": "narration",
          "text": "后院传来一声响，大鱼从柜台后面跳出来，叼起地上的一段旧剑穗，往她脚边一放，然后大摇大摆地走开了。",
          "next": "m_06"
        },
        "m_06": {
          "speaker": "苏云晚",
          "text": "你从哪捡来的破东西。",
          "next": "m_07"
        },
        "m_07": {
          "speaker": "苏明",
          "text": "云晚。",
          "next": "m_08"
        },
        "m_08": {
          "speaker": "苏明",
          "text": "去吧。不管测出什么，记得回来吃饭。",
          "next": "m_09"
        },
        "m_09": {
          "type": "narration",
          "text": "爹向来不多说话。这句\u201c记得回来吃饭\u201d，却让她鼻子微微一酸。她把围裙解下来挂在门边的钉子上，出门了。",
          "next": "m_end"
        },
        "m_end": {
          "type": "event",
          "event": "morning_done"
        }
      }
    },

    "market": {
      "title": "集市·平安符",
      "start": "mk_02",
      "nodes": {
        "mk_01": {
          "type": "narration",
          "text": "集市已经热闹起来。卖糖葫芦的，卖鸡鸭的，卖针线布料的。今日多了许多外乡人，都是来看太平宗招募热闹的。",
          "next": "mk_02"
        },
        "mk_02": {
          "speaker": "老婆婆",
          "text": "姑娘，买一张平安符吧。出门在外，保个平安。",
          "next": "mk_03"
        },
        "mk_03": {
          "speaker": "苏云晚",
          "text": "婆婆，我今天去测灵根，也不知道……罢了，多少钱？",
          "next": "mk_04"
        },
        "mk_04": {
          "speaker": "老婆婆",
          "text": "灵根啊。",
          "next": "mk_05"
        },
        "mk_05": {
          "speaker": "老婆婆",
          "text": "姑娘，你可曾想过，有些路，是灵石测不出来的。",
          "next": "mk_06"
        },
        "mk_06": {
          "speaker": "苏云晚",
          "text": "婆婆这话是什么意思？",
          "next": "mk_07"
        },
        "mk_07": {
          "speaker": "老婆婆",
          "text": "不要钱。就当老婆子送你一程。",
          "next": "mk_08"
        },
        "mk_08": {
          "type": "narration",
          "text": "苏云晚低头看那张符，墨迹陈旧，符文却像刚写的，还有些许暖意。当她抬起头，老婆婆不见了——连人带篮子，像是从未站在那里。"
        }
      }
    },

    "test": {
      "title": "灵根测试",
      "start": "t_01",
      "nodes": {
        "t_01": {
          "type": "narration",
          "text": "测灵台搭在城东空地上。长长的队列，百余人，大多是城里的年轻人，也有几个一脸风尘的外乡人。那块灵石有拳头大，据说能感应持握者的根骨高低。",
          "next": "t_02"
        },
        "t_02": {
          "speaker": "测验师",
          "text": "下一个。",
          "next": "t_03"
        },
        "t_03": {
          "type": "narration",
          "text": "苏云晚走上台。灵石很凉，像一块普通的河边卵石。她将手扣上去，等了很久，灵石纹丝不动。",
          "next": "t_04"
        },
        "t_04": {
          "speaker": "测验师",
          "text": "无灵根。",
          "next": "t_05"
        },
        "t_05": {
          "type": "narration",
          "text": "台下有人窃窃私语，有人轻轻笑了一声，也有人叹气。风来了，把她额前的碎发吹起来。",
          "next": "t_06"
        },
        "t_06": {
          "speaker": "测验师",
          "text": "姑娘，下去吧。后面还有人。",
          "next": "t_07"
        },
        "t_07": {
          "type": "choice",
          "text": "十八年。这是她第一次站在这么多人面前，成为那个\u201c什么都没有\u201d的人。",
          "choices": [
            { "text": "没什么大不了的", "next": "t_08a" },
            { "text": "我不信",          "next": "t_08b" }
          ]
        },
        "t_08a": {
          "speaker": "苏云晚",
          "text": "没什么大不了的。无非是，命里没有这条路罢了。",
          "next": "t_09a"
        },
        "t_09a": {
          "type": "narration",
          "text": "她走下台，脚步很稳。只是眼眶有些发热，她把头微微偏了偏，不让人看见。",
          "next": "t_10"
        },
        "t_08b": {
          "speaker": "苏云晚",
          "text": "等一下。再测一次。",
          "next": "t_09b"
        },
        "t_09b": {
          "speaker": "测验师",
          "text": "灵石不说谎，姑娘。后面排着人，不要耽搁。",
          "next": "t_09b2"
        },
        "t_09b2": {
          "type": "narration",
          "text": "她握了握拳，松开，走下台。脚步是稳的，但指甲在手心留了四道月牙痕。",
          "next": "t_10"
        },
        "t_10": {
          "type": "narration",
          "text": "天色渐暗。她没有直接回家。"
        }
      }
    },

    "temple": {
      "title": "废庙·独白",
      "start": "tp_01",
      "nodes": {
        "tp_01": {
          "type": "narration",
          "text": "城外有座废庙，神像缺了半张脸，香案已倒，蛛网结在檐角。苏云晚在里面坐了很久，直到星子出来，才想起抬头。",
          "next": "tp_02"
        },
        "tp_02": {
          "speaker": "苏云晚",
          "text": "年年。大鱼。",
          "next": "tp_03"
        },
        "tp_03": {
          "speaker": "苏云晚",
          "text": "就算什么灵根都没有，这双手还在。",
          "next": "tp_04"
        },
        "tp_04": {
          "type": "narration",
          "text": "远处传来声音。不像野兽嗥叫，更像是——某种东西正在接近，朝这里来。",
          "next": "tp_05"
        },
        "tp_05": {
          "speaker": "苏云晚",
          "text": "……妖？",
          "next": "tp_06"
        },
        "tp_06": {
          "type": "narration",
          "text": "她想跑。但年年和大鱼每天都走这条路回家。今天下午她出门时，年年还在铺子门口冲她挥手。",
          "next": "tp_07"
        },
        "tp_07": {
          "speaker": "苏云晚",
          "text": "不行。不能死在这里，也不能让它们留在这里。",
          "next": "tp_08"
        },
        "tp_08": {
          "type": "event",
          "event": "trigger_battle"
        }
      }
    },

    "after_battle": {
      "title": "战斗后·顾飞白",
      "start": "ab_01",
      "nodes": {
        "ab_01": {
          "type": "narration",
          "text": "她不知道自己是怎么赢的。手还在抖，腿也软，但她站着——妖已经化成一地黑灰，被夜风吹散了。",
          "next": "ab_02"
        },
        "ab_02": {
          "speaker": "顾飞白",
          "text": "不错。",
          "next": "ab_03"
        },
        "ab_03": {
          "speaker": "苏云晚",
          "text": "你是谁？",
          "next": "ab_04"
        },
        "ab_04": {
          "speaker": "顾飞白",
          "text": "一个路过的人。在这里站了一会儿，看了场好戏。",
          "next": "ab_05"
        },
        "ab_05": {
          "speaker": "顾飞白",
          "text": "你无灵根，却能御妖。你知道这意味着什么吗？",
          "next": "ab_06"
        },
        "ab_06": {
          "speaker": "苏云晚",
          "text": "意味着什么？",
          "next": "ab_07"
        },
        "ab_07": {
          "speaker": "顾飞白",
          "text": "意味着有人动了手脚。也意味着，你走的路，或许比那些五灵根的人更难——也更远。",
          "next": "ab_08"
        },
        "ab_08": {
          "speaker": "顾飞白",
          "text": "跟我走。我知道一些事，或许对你有用。",
          "next": "ab_choice"
        },
        "ab_choice": {
          "type": "choice",
          "text": "苏云晚抬起头看天。月亮已经出来了，大而圆。家里的灯这时候应该亮着，爹做的菜大概还热着。",
          "choices": [
            { "text": "一起走",      "next": "ab_together_01", "event": "" },
            { "text": "先回去看爹", "next": "ab_return_01",   "event": "" }
          ]
        },
        "ab_together_01": {
          "speaker": "苏云晚",
          "text": "好。",
          "next": "ab_together_02"
        },
        "ab_together_02": {
          "type": "narration",
          "text": "她只带了那张平安符，还有腰间装了半壶水的葫芦。走出废庙的时候，她没有回头。",
          "next": "ab_together_end"
        },
        "ab_together_end": {
          "type": "event",
          "event": "chapter_end_path_a"
        },
        "ab_return_01": {
          "speaker": "苏云晚",
          "text": "我得先回去。",
          "next": "ab_return_02"
        },
        "ab_return_02": {
          "speaker": "顾飞白",
          "text": "也好。三日后，城西槐树林。不来，便算了。",
          "next": "ab_return_03"
        },
        "ab_return_03": {
          "type": "narration",
          "text": "她回到家，灯还亮着，但爹不在。桌上压着一封信，字迹潦草，像是赶着写的。",
          "next": "ab_return_end"
        },
        "ab_return_end": {
          "type": "event",
          "event": "return_home"
        }
      }
    },

    "letter": {
      "title": "爹的信",
      "hidden": true,
      "start": "lt_01",
      "nodes": {
        "lt_01": {
          "type": "narration",
          "text": "信折了两折，压在油灯下面，灯芯烧得很小，火苗一点一点地跳。",
          "next": "lt_02"
        },
        "lt_02": {
          "speaker": "苏明〔信〕",
          "text": "云晚，爹去外面走走，几日就回，你别担心。家里米缸是满的，咸菜罐子在左边橱柜里，别找错了。",
          "next": "lt_03"
        },
        "lt_03": {
          "speaker": "苏明〔信〕",
          "text": "年年喜欢喝甜汤，睡前记得给她熬一碗。大鱼怕黑这件事你别说出去，晚上记得给他留一盏灯。",
          "next": "lt_04"
        },
        "lt_04": {
          "speaker": "苏明〔信〕",
          "text": "爹这一生，没什么大本事，就是在这片地上种了些菜，养了些鸡，把你们几个拉扯大。说起来，也已经够了。",
          "next": "lt_05"
        },
        "lt_05": {
          "speaker": "苏明〔信〕",
          "text": "云晚，你要走，就走吧。山高路远，爹拦不住，也不想拦。只是记住一句话：活着，比赢了更要紧。",
          "next": "lt_06"
        },
        "lt_06": {
          "type": "narration",
          "text": "信的末尾没有署名。她把信仔细折好，夹进了那张平安符里面。",
          "next": "lt_07"
        },
        "lt_07": {
          "speaker": "苏云晚",
          "text": "爹。",
          "next": "lt_end"
        },
        "lt_end": {
          "type": "event",
          "event": "chapter_end_path_b"
        }
      }
    }

  }
}
